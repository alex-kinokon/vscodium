+function buildPackagedDependencies(extensionPath: string, dependencies: string[]): Promise<void> {
+	if (process.platform !== 'darwin' || dependencies.length === 0) {
+		return Promise.resolve();
+	}
+
+	return Promise.all(dependencies.map(dependency => {
+		const dependencyPath = path.join(extensionPath, 'node_modules', dependency);
+		const bindingGypPath = path.join(dependencyPath, 'binding.gyp');
+
+		if (!fs.existsSync(bindingGypPath)) {
+			return Promise.resolve();
+		}
+
+		return new Promise<void>((resolve, reject) => {
+			fancyLog(`Building packaged dependency: ${ansiColors.yellow(path.join(path.basename(extensionPath), 'node_modules', dependency))}`);
+
+			const proc = cp.execFile('npm', ['run', 'build', '--if-present'], { cwd: dependencyPath }, error => {
+				if (error) {
+					return reject(error);
+				}
+
+				return resolve();
+			});
+
+			proc.stdout!.on('data', (data) => {
+				fancyLog(`${ansiColors.green('building dependency')}: ${data.toString('utf8')}`);
+			});
+
+			proc.stderr!.on('data', (data) => {
+				fancyLog(`${ansiColors.yellow('building dependency')}: ${data.toString('utf8')}`);
+			});
+		});
+	})).then(() => undefined);
+}
